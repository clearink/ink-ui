{
  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      // 这样才能识别其他子包的类型
      "@ink-ui/core": ["../components/src"],
      "@ink-ui/core/*": ["../components/src/*"],
      "@ink-ui/icons": ["../icons/src"],
      "@ink-ui/icons/*": ["../icons/src/*"],
      "@ink-ui/validator": ["../validator/src"],
      "@ink-ui/validator/*": ["../validator/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
